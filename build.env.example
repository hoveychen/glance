# Copy this file to build.env and fill in your values.
# build.env is gitignored and will NOT be committed.

# Signing identity names (run: security find-identity -v)
# Example: "Developer ID Application: Yuheng Chen (6HU93XQG5B)"
DEVELOPER_ID_APP="Developer ID Application: YOUR_NAME (TEAM_ID)"
# Example: "Developer ID Installer: Yuheng Chen (6HU93XQG5B)"
DEVELOPER_ID_INSTALLER="Developer ID Installer: YOUR_NAME (TEAM_ID)"

# Apple Team ID
TEAM_ID="6HU93XQG5B"

# App Store Connect API Key for notarization
# Download from: https://appstoreconnect.apple.com/access/integrations/api
NOTARY_API_KEY="/path/to/AuthKey_XXXXXX.p8"
NOTARY_API_KEY_ID="XXXXXXXXXX"
NOTARY_API_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
